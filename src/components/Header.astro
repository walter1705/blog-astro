---
import { SITE_TITLE, BASE } from '../consts';

const base = BASE;
const pathname = Astro.url.pathname;

const links = [
  { href: base, label: 'Home' },
  { href: `${base}blog`, label: 'Blog' },
  { href: `${base}terminal`, label: 'Terminal' },
  { href: `${base}dashboard`, label: 'Dashboard' },
];
---

<header class="sticky top-0 z-50 bg-gray-950/90 backdrop-blur border-b border-gray-800">
  <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={base} class="font-mono font-bold text-indigo-400 hover:text-indigo-300 transition-colors">
      {SITE_TITLE}
    </a>

    <div class="flex items-center gap-1">
      {links.map(({ href, label }) => {
        const isActive = href === base ? pathname === base : pathname.startsWith(href);
        return (
          <a
            href={href}
            class={[
              'px-3 py-1.5 rounded-md text-sm font-mono transition-colors',
              isActive
                ? 'text-indigo-400 bg-indigo-500/10'
                : 'text-gray-400 hover:text-gray-200 hover:bg-gray-800',
            ].join(' ')}
          >
            {label}
          </a>
        );
      })}
    </div>
  </nav>
</header>
