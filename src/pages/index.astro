---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION, BASE } from '../consts';
import { projects } from '../data/projects';

const base = BASE;

const techStack = [
  'React', 'Astro', 'TypeScript', 'Tailwind CSS',
  'Node.js', 'NestJS', 'PostgreSQL', 'Docker',
  'Phoenix', 'Grafana', 'AWS',
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      /* Typing animation */
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
      }
      .cursor {
        display: inline-block;
        width: 2px;
        height: 1.1em;
        background: #818cf8;
        vertical-align: text-bottom;
        animation: blink 1s step-end infinite;
        margin-left: 2px;
      }
    </style>
  </head>
  <body class="bg-gray-950 text-gray-100 antialiased font-mono">
    <Header />

    <main>
      <!-- HERO -->
      <section class="min-h-[90vh] flex items-center justify-center px-4 py-24">
        <div class="max-w-4xl mx-auto text-center">

          <!-- Typing animation line -->
          <p class="text-indigo-400 text-sm tracking-widest mb-6 h-6">
            <span id="typed-text"></span><span class="cursor"></span>
          </p>

          <h1
            class="text-5xl md:text-7xl font-bold mb-6 leading-tight"
            style="background: linear-gradient(to right, #818cf8, #c084fc, #f472b6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
          >
            Quality.<br />Clarity.<br />Passion.
          </h1>

          <p class="text-gray-400 text-xl md:text-2xl max-w-2xl mx-auto mb-10 leading-relaxed">
            Junior Fullstack Developer. Obsessed with fundamentals,
            clean architecture, and building software that lasts.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={`${base}blog`}
              class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 transition-colors text-white font-semibold px-8 py-4 rounded-lg"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              Read the Blog
            </a>
            <a
              href={`${base}terminal`}
              class="inline-flex items-center gap-2 border border-indigo-500 hover:bg-indigo-500/10 transition-colors text-indigo-400 font-semibold px-8 py-4 rounded-lg"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
              Open Terminal
            </a>
          </div>
        </div>
      </section>

      <!-- PROJECTS -->
      <section id="projects" class="py-24 px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Projects</h2>
          <p class="text-gray-400 text-center mb-16 max-w-xl mx-auto">
            Code that solves real problems, not throwaway demos.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {projects.map((project) => (
              <article class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-indigo-500/50 transition-colors group">
                <div class="aspect-video overflow-hidden">
                  <img
                    src={project.image}
                    alt={project.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold mb-2 text-white">{project.title}</h3>
                  <p class="text-gray-400 text-sm mb-4 leading-relaxed">{project.description}</p>

                  <div class="flex flex-wrap gap-2 mb-6">
                    {project.tech.map((t) => (
                      <span class="text-xs bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded-full px-3 py-1">
                        {t}
                      </span>
                    ))}
                  </div>

                  <div class="flex gap-4">
                    {project.github && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition-colors"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                        GitHub
                      </a>
                    )}
                    {project.demo && (
                      <a
                        href={project.demo}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-sm text-indigo-400 hover:text-indigo-300 transition-colors"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                        Demo
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- TECH STACK -->
      <section id="stack" class="py-24 px-4 bg-gray-900/50">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Tech Stack</h2>
          <p class="text-gray-400 mb-16 max-w-xl mx-auto">
            Tools I actually know. Not just ones I've heard of.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            {techStack.map((tech) => (
              <span class="bg-gray-800 hover:bg-gray-700 border border-gray-700 hover:border-indigo-500/50 transition-all text-gray-300 text-sm px-4 py-2 rounded-lg cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </section>

      <!-- EXPLORE -->
      <section class="py-24 px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">Explore</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <a href={`${base}blog`} class="group p-8 bg-gray-900 border border-gray-800 rounded-xl hover:border-indigo-500/50 transition-all text-center">
              <div class="flex justify-center mb-4 text-indigo-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">Blog</h3>
              <p class="text-gray-400 text-sm">Architecture, patterns and unfiltered technical opinions.</p>
            </a>
            <a href={`${base}terminal`} class="group p-8 bg-gray-900 border border-gray-800 rounded-xl hover:border-green-500/50 transition-all text-center">
              <div class="flex justify-center mb-4 text-green-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">Terminal</h3>
              <p class="text-gray-400 text-sm">Browse this portfolio from an interactive CLI.</p>
            </a>
            <a href={`${base}dashboard`} class="group p-8 bg-gray-900 border border-gray-800 rounded-xl hover:border-purple-500/50 transition-all text-center">
              <div class="flex justify-center mb-4 text-purple-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-2">Dashboard</h3>
              <p class="text-gray-400 text-sm">Metrics and visualizations. Coming soon.</p>
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-gray-800 py-12 px-4">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <p class="text-gray-500 text-sm">walter@portfolio:~$ &gt; built with Astro + Tailwind</p>
        <div class="flex items-center gap-6">
          <a
            href="https://github.com/walter1705"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-white transition-colors"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
          <a
            href="mailto:waltergranada77@gmail.com"
            class="text-gray-500 hover:text-pink-400 transition-colors"
            aria-label="Email"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  // The ">" stays fixed. Only the suffix is typed/deleted.
  const suffixes = [' ls Projects/', ' cat about.txt', ' git log --oneline', ' npm run dev'];
  const el = document.getElementById('typed-text')!;
  const PREFIX = '>';
  let phraseIndex = 0;
  let charIndex = 0;
  let deleting = false;
  const TYPING_SPEED = 80;
  const DELETE_SPEED = 45;
  const PAUSE_AFTER_TYPE = 1800;
  const PAUSE_AFTER_DELETE = 300;

  function tick() {
    const suffix = suffixes[phraseIndex % suffixes.length];

    if (!deleting) {
      charIndex++;
      el.textContent = PREFIX + suffix.slice(0, charIndex);
      if (charIndex === suffix.length) {
        deleting = true;
        setTimeout(tick, PAUSE_AFTER_TYPE);
        return;
      }
    } else {
      charIndex--;
      el.textContent = PREFIX + suffix.slice(0, charIndex);
      if (charIndex === 0) {
        deleting = false;
        phraseIndex++;
        setTimeout(tick, PAUSE_AFTER_DELETE);
        return;
      }
    }

    setTimeout(tick, deleting ? DELETE_SPEED : TYPING_SPEED);
  }

  // Start with ">" visible immediately
  el.textContent = PREFIX;
  setTimeout(tick, 600);
</script>
